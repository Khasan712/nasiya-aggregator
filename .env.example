# ---- Database ----
POSTGRES_USER=nasiya
POSTGRES_PASSWORD=nasiya_dev_pw
POSTGRES_DB=nasiya
POSTGRES_HOST=localhost
POSTGRES_PORT=5433

# SQLAlchemy async URL (used by backend)
DATABASE_URL=postgresql+asyncpg://nasiya:nasiya_dev_pw@localhost:5433/nasiya
# Sync URL for Alembic migrations
DATABASE_URL_SYNC=postgresql+psycopg://nasiya:nasiya_dev_pw@localhost:5433/nasiya

# ---- Redis ----
REDIS_URL=redis://localhost:6380/0

# ---- Backend ----
APP_ENV=development
APP_NAME=nasiya-backend
APP_HOST=0.0.0.0
APP_PORT=8000
# Generate with: openssl rand -hex 32
SECRET_KEY=change-me-32-bytes-hex
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30
# Comma-separated origins
CORS_ORIGINS=http://localhost:3000

# ---- Bot ----
# Get from @BotFather
BOT_TOKEN=
# Comma-separated Telegram user IDs that get admin role on /start
BOT_ADMIN_IDS=

# ---- Backend API base URL used by bot & dashboard ----
BACKEND_URL=http://localhost:8000

# ---- Dashboard ----
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

# ---- Internal service token (dashboard → backend writes) ----
# Generate with: openssl rand -hex 24
SERVICE_TOKEN=
DASHBOARD_SERVICE_TOKEN=
