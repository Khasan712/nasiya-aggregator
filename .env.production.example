# ============================================================================
# Nasiya Aggregator — production environment template
#
# Server'da bir martalik:
#   cp .env.production.example .env
#   nano .env       # Quyidagi __PLACEHOLDER__ qiymatlarini to'ldiring
#
# Kuchli secret generatsiyasi:
#   openssl rand -hex 32      # SECRET_KEY uchun
#   openssl rand -hex 24      # SERVICE_TOKEN uchun
#   openssl rand -base64 32   # POSTGRES_PASSWORD uchun
# ============================================================================

# --- Server identification -----------------------------------------------
APP_ENV=production
TZ=Asia/Tashkent

# --- Host portlar (loyihalar bilan to'qnashmasin) ------------------------
# Bu portlar HOST mashinada qaysi raqamda ochiladi (faqat 127.0.0.1 ga
# bog'lanadi — internetdan ko'rinmaydi). Server'da boshqa loyihalar 8000 yoki
# 3000 da turibsa, bu yerda boshqa raqam yozing va `deploy/scripts/render_nginx.sh`
# ni qayta ishga tushiring (deploy.sh avtomat qiladi).
BACKEND_HOST_PORT=8000
DASHBOARD_HOST_PORT=3000

# --- Nginx server_name ---------------------------------------------------
# nginx config'i shu nom bo'yicha so'rovlarni qo'shib oladi (default_server
# emas — boshqa loyihalar bilan to'qnashmaslik uchun).
#
# Variantlar:
#   IP bilan:     NGINX_SERVER_NAME=1.2.3.4
#   Domain bilan: NGINX_SERVER_NAME=nasiya.uz www.nasiya.uz
#   Catch-all:    NGINX_SERVER_NAME=_           (boshqa default yo'q bo'lsa)
NGINX_SERVER_NAME=_

# --- Postgres (docker container) -----------------------------------------
POSTGRES_USER=nasiya
POSTGRES_PASSWORD=__CHANGE_ME__
POSTGRES_DB=nasiya
# Note: hostname `postgres` is the docker service name from docker-compose.prod.yml
DATABASE_URL=postgresql+asyncpg://nasiya:__CHANGE_ME__@postgres:5432/nasiya
DATABASE_URL_SYNC=postgresql+psycopg://nasiya:__CHANGE_ME__@postgres:5432/nasiya

# --- Redis ---------------------------------------------------------------
REDIS_URL=redis://redis:6379/0

# --- Backend security ----------------------------------------------------
# JWT signing key — generate with `openssl rand -hex 32`
SECRET_KEY=__CHANGE_ME_64_HEX_CHARS__
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# Trusted internal token for dashboard ↔ backend writes — generate with `openssl rand -hex 24`
SERVICE_TOKEN=__CHANGE_ME_48_HEX_CHARS__
# Same value as SERVICE_TOKEN — read by the dashboard's server-side code
DASHBOARD_SERVICE_TOKEN=__SAME_AS_SERVICE_TOKEN__

# Comma-separated origins allowed for browser CORS.
# Example: http://1.2.3.4 , https://nasiya.uz
CORS_ORIGINS=http://YOUR_SERVER_IP

# --- Telegram bot --------------------------------------------------------
# Get from @BotFather
BOT_TOKEN=__CHANGE_ME__
# Comma-separated Telegram numeric user IDs (use @userinfobot to get yours).
# These users get admin notifications about broken URLs etc.
BOT_ADMIN_IDS=

# --- Where the dashboard talks to the backend ----------------------------
# Browser-facing — what URL the user types into their browser. Nginx will
# rewrite /api/v1/* to the backend container, so this is just the public host.
NEXT_PUBLIC_BACKEND_URL=http://YOUR_SERVER_IP

# --- Initial admin login (used by seed script ONCE on first deploy) ------
ADMIN_EMAIL=admin@nasiya.uz
ADMIN_PASSWORD=__CHANGE_ME_AFTER_FIRST_LOGIN__
